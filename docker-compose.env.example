# Copy this file to .env and fill in all values before running docker-compose.
# Never commit .env to git.

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=baby_feeding
MYSQL_USER=appuser
MYSQL_PASSWORD=change_me_app_password

# ── Backend ────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated allowed origins — use your actual production domain
CORS_ORIGINS=https://yourdomain.com

# ── Frontend (baked into JS bundle at build time) ──────────────────────────
# These must point to your public-facing domain, no trailing slash.
# /api prefix matches the nginx proxy_pass rule.
VITE_API_URL=https://yourdomain.com/api
VITE_WS_URL=wss://yourdomain.com/api
